#!/bin/bash

echo "🗑️  Dotfile Uninstall"
echo "====================="

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
log_info() { echo -e "${BLUE}ℹ️  $1${NC}"; }
log_success() { echo -e "${GREEN}✅ $1${NC}"; }
log_warning() { echo -e "${YELLOW}⚠️  $1${NC}"; }
log_error() { echo -e "${RED}❌ $1${NC}"; }

# Set up environment variables
export DOTFILES="$HOME/dotfiles"

# Remove symlinks
log_info "Removing dotfile symlinks..."

for file in .zshrc .vimrc .gitconfig .hgrc; do
    if [ -L "$HOME/$file" ]; then
        rm "$HOME/$file"
        log_success "Removed $file symlink"
    fi
done

# Restore backups if they exist (checks for timestamped backups)
log_info "Checking for backups to restore..."

restore_latest_backup() {
    local file=$1
    # Look for both exact matches and timestamped versions
    local latest_backup=$(ls -t "$DOTFILES/dotfile_backups/${file}_backup"* 2>/dev/null | head -n 1)
    if [ -n "$latest_backup" ]; then
        cp "$latest_backup" "$HOME/$file"
        log_success "Restored $file from latest backup: $(basename "$latest_backup")"
    else
        log_info "No backup found for $file"
    fi
}

restore_latest_backup ".zshrc"
restore_latest_backup ".vimrc"
restore_latest_backup ".gitconfig"
restore_latest_backup ".hgrc"

# Remove vim spell directory
if [ -d "$HOME/.vim/spell" ]; then
    rm -rf "$HOME/.vim/spell"
    log_success "Removed vim spell directory"
fi

# Remove vim directory if empty
if [ -d "$HOME/.vim" ] && [ -z "$(ls -A $HOME/.vim)" ]; then
    rmdir "$HOME/.vim"
    log_success "Removed empty vim directory"
fi

# Remove fonts
log_info "Removing installed fonts..."
if [ -d "$HOME/Library/Fonts" ]; then
    # Remove powerline fonts
    find "$HOME/Library/Fonts" -name "*Powerline*" -delete 2>/dev/null || true
    log_success "Removed powerline fonts"
fi

# Clean up mise tools (optional)
read -p "Do you want to remove all tools installed via mise? [y/n] " yn
case $yn in
    [Yy]* )
        log_info "Removing mise tools..."
        if command -v mise &> /dev/null; then
            mise uninstall --all
            log_success "Removed all mise tools"
        else
            log_warning "mise command not found, skipping tool removal"
        fi
        ;;
    * )
        log_info "Keeping mise tools installed"
        ;;
esac

# Remove mise itself (optional)
read -p "Do you want to remove mise-en-place? [y/n] " yn
case $yn in
    [Yy]* )
        log_info "Removing mise-en-place..."
        if command -v brew &> /dev/null && brew list mise &>/dev/null; then
            brew uninstall mise
            log_success "Removed mise via Homebrew"
        fi
        
        # Also clean up manual installation
        if [ -d "$HOME/.local/share/mise" ] || [ -f "$HOME/.local/bin/mise" ]; then
            rm -rf "$HOME/.local/share/mise"
            rm -f "$HOME/.local/bin/mise"
            log_success "Removed manual mise installation"
        fi
        ;;
    * )
        log_info "Keeping mise-en-place installed"
        ;;
esac

log_success "Uninstall completed!"
echo
echo "Note: Your dotfiles directory ($DOTFILES) has not been removed."
echo "You can delete it manually if you no longer need it."
echo
echo "To completely start fresh, you may also want to:"
echo "1. Remove Oh My Zsh: rm -rf ~/.oh-my-zsh"
echo "2. Remove Homebrew tools: brew uninstall git vim tmux autojump eza bat fd ripgrep direnv"
