# Ghostty configuration (portable via ~/dotfiles).
# Linked to ~/.config/ghostty/config by `setup`. Works on macOS and Linux/WSL.
# Reference: https://ghostty.org/docs/config
# Reload after edits: Cmd+Shift+, (macOS). List options: `ghostty +show-config --default=true`.

# --- Appearance ---
# JetBrainsMono Nerd Font: ligatures + the full Nerd Font glyph set (all icons).
# The "Mono" variant keeps icons at a single cell width so status bars stay aligned.
font-family = JetBrainsMono Nerd Font Mono
font-size = 18
# Use the SemiBold face for normal text (bold stays Bold, i.e. heavier).
font-style = SemiBold
# Match italics to the semibold body weight instead of regular-weight italic.
font-style-italic = SemiBold Italic

# `ghostty +list-themes` for options. For OS-driven light/dark use the form
# `light:<theme>,dark:<theme>` (e.g. light:Rose Pine Dawn,dark:Rose Pine Moon).
theme = Rose Pine Moon

# Frosted-glass background. Opacity: 0=transparent, 1=opaque. Blur is a radius
# (macOS-native; on Linux depends on the compositor). Keep it subtle for legibility.
background-opacity = 0.85
background-blur = 50

window-padding-x = 8
window-padding-y = 6
# Slim titlebar with tabs integrated into it: minimal chrome while keeping a
# clickable tab bar (macOS renders tabs in the titlebar, so a fully hidden
# titlebar would remove them). macOS-only (ignored elsewhere).
macos-titlebar-style = tabs
cursor-style = block
# no-cursor: keep a block cursor everywhere (integration otherwise makes it a bar
#   at the prompt). ssh-terminfo: auto-install Ghostty's terminfo on hosts you SSH
#   to (fixes "xterm-ghostty: unknown terminal type" + duplicated input remotely).
#   ssh-env: fall back to propagating TERM/color env vars when terminfo can't be
#   installed. These merge with defaults (title/path/etc. stay on).
shell-integration-features = no-cursor,ssh-terminfo,ssh-env
mouse-hide-while-typing = true

# --- Behavior ---
scrollback-limit = 10000000
copy-on-select = clipboard
confirm-close-surface = false
window-save-state = always

# On macOS, let the left Option key send Alt so terminal Alt-keybinds work.
# Ignored on Linux, so it stays portable.
macos-option-as-alt = left

# Multiplexing (panes/sessions/persistence) is delegated to herdr / zellij / tmux,
# so Ghostty's own splits are intentionally left minimal here.

# --- Machine-specific overrides ---
# Optional, untracked. Create ~/.config/ghostty/config.local on any machine that
# needs different settings (e.g. font-size on a 4K display). The `?` makes it
# optional: absent -> ignored, present -> overrides the values above.
config-file = ?config.local
